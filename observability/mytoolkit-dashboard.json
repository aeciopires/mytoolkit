      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "mytoolkit_tool_usage_total", "legendFormat": "{{tool}}", "format": "time_series", "instant": true, "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "continuous-BlPu" }, "min": 0 }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "showUnfilled": true, "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 13, "type": "table", "title": "Tool Usage Ranking",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 39 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sort_desc(sum(mytoolkit_tool_usage_total) by (tool))", "format": "table", "instant": true, "refId": "A" }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Value", "desc": true }] },
      "description": "Same ranking the app's own GET /api/v1/metrics/ranking endpoint derives from this metric."
    },

    { "id": 104, "type": "row", "title": "MCP Server (mytoolkit_mcp_*)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 }, "panels": [] },

