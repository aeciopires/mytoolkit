# Interface the HTTP server binds to.
MYTOOLKIT_HOST=0.0.0.0

# TCP port the HTTP server listens on.
MYTOOLKIT_PORT=8080

# zerolog level: debug, info, warn, error.
MYTOOLKIT_LOG_LEVEL=info

# MCP server transport: stdio or http. Only used by `mytoolkit mcp`.
MYTOOLKIT_MCP_TRANSPORT=stdio

# TCP port `mytoolkit mcp --transport http` listens on.
MYTOOLKIT_MCP_PORT=8081
